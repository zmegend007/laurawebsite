{% doc %}
  @prompt
    A testimonial section with image ratio 2:3  where the text can be added to either the right or left side of it. Up to 6 slots. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-testimonial-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-testimonial-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    height: 100%;
  }

  .ai-testimonial-content-{{ ai_gen_id }}.ai-text-left-{{ ai_gen_id }} {
    flex-direction: row-reverse;
  }

  .ai-testimonial-image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 40%;
    position: relative;
    overflow: hidden;
  }

  .ai-testimonial-image-wrapper-{{ ai_gen_id }}::before {
    content: '';
    display: block;
    padding-top: 150%;
  }

  .ai-testimonial-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-testimonial-text-wrapper-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.text_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-testimonial-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_font_size }}px;
    line-height: 1.6;
    color: {{ block.settings.quote_color }};
    margin: 0 0 20px 0;
    font-style: italic;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.author_color }};
    margin: 0 0 5px 0;
  }

  .ai-testimonial-role-{{ ai_gen_id }} {
    font-size: {{ block.settings.role_font_size }}px;
    color: {{ block.settings.role_color }};
    margin: 0;
  }

  .ai-testimonial-rating-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 15px;
  }

  .ai-testimonial-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-testimonial-content-{{ ai_gen_id }},
    .ai-testimonial-content-{{ ai_gen_id }}.ai-text-left-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-testimonial-image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 auto;
    }

    .ai-testimonial-image-wrapper-{{ ai_gen_id }}::before {
      padding-top: 150%;
    }
  }
{% endstyle %}

<testimonials-block-{{ ai_gen_id }} class="ai-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign enabled_key = 'testimonial_' | append: i | append: '_enabled'
          assign image_key = 'testimonial_' | append: i | append: '_image'
          assign quote_key = 'testimonial_' | append: i | append: '_quote'
          assign author_key = 'testimonial_' | append: i | append: '_author'
          assign role_key = 'testimonial_' | append: i | append: '_role'
          assign rating_key = 'testimonial_' | append: i | append: '_rating'
          assign text_position_key = 'testimonial_' | append: i | append: '_text_position'

          assign enabled = block.settings[enabled_key]
          assign image = block.settings[image_key]
          assign quote = block.settings[quote_key]
          assign author = block.settings[author_key]
          assign role = block.settings[role_key]
          assign rating = block.settings[rating_key]
          assign text_position = block.settings[text_position_key]
        %}

        {% if enabled %}
          <div class="ai-testimonial-item-{{ ai_gen_id }}">
            <div class="ai-testimonial-content-{{ ai_gen_id }} {% if text_position == 'left' %}ai-text-left-{{ ai_gen_id }}{% endif %}">
              <div class="ai-testimonial-image-wrapper-{{ ai_gen_id }}">
                {% if image %}
                  <img
                    src="{{ image | image_url: width: 600 }}"
                    alt="{{ author | escape }}"
                    loading="lazy"
                    width="600"
                    height="900"
                    class="ai-testimonial-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-testimonial-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-testimonial-text-wrapper-{{ ai_gen_id }}">
                {% if block.settings.show_rating and rating > 0 %}
                  <div class="ai-testimonial-rating-{{ ai_gen_id }}">
                    {% for star in (1..rating) %}
                      <svg class="ai-testimonial-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {% endfor %}
                  </div>
                {% endif %}

                {% if quote != blank %}
                  <p class="ai-testimonial-quote-{{ ai_gen_id }}">{{ quote }}</p>
                {% endif %}

                {% if author != blank %}
                  <p class="ai-testimonial-author-{{ ai_gen_id }}">{{ author }}</p>
                {% endif %}

                {% if role != blank %}
                  <p class="ai-testimonial-role-{{ ai_gen_id }}">{{ role }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</testimonials-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialsBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('testimonials-block-{{ ai_gen_id }}', TestimonialsBlock{{ ai_gen_id }});
  })();
</script>

