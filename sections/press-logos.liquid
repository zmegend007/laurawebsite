{%- style -%}
  .press-logos {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    text-align: center;
  }

  .press-logos__label {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.2;
    margin-bottom: 3rem;
    font-weight: 500;
  }

  .press-logos__row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media (max-width: 575px) {
    .press-logos__row {
      gap: 1.5rem 2.5rem;
    }
  }

  .press-logos__item {
    opacity: 0.3;
    transition: opacity 0.4s ease;
  }

  .press-logos__item:hover {
    opacity: 0.6;
  }

  /* Image logos */
  .press-logos__item img {
    height: {{ section.settings.logo_height }}px;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%);
  }

  /* Text wordmarks */
  .press-logos__wordmark {
    font-family: var(--font-heading-family);
    font-size: clamp(1.1rem, 2vw, {{ section.settings.wordmark_size }}rem);
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    white-space: nowrap;
    text-decoration: none;
    color: rgb(var(--color-foreground));
  }
{%- endstyle -%}

<section class="press-logos color-{{ section.settings.color_scheme }}">
  {% if section.settings.label != blank %}
    <p class="press-logos__label">{{ section.settings.label }}</p>
  {% endif %}

  <div class="press-logos__row">
    {% for block in section.blocks %}
      {% if block.settings.link != blank %}
        <a href="{{ block.settings.link }}" target="_blank" rel="noopener" class="press-logos__item" {{ block.shopify_attributes }}>
      {% else %}
        <div class="press-logos__item" {{ block.shopify_attributes }}>
      {% endif %}

        {% if block.settings.logo != blank %}
          <img
            src="{{ block.settings.logo | image_url: height: 120 }}"
            alt="{{ block.settings.name | escape }}"
            loading="lazy"
            height="{{ section.settings.logo_height }}"
          >
        {% else %}
          <span class="press-logos__wordmark">{{ block.settings.name }}</span>
        {% endif %}

      {% if block.settings.link != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Press Logos",
  "tag": "section",
  "class": "section-press-logos",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "As Seen In"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "wordmark_size",
      "label": "Wordmark text size (rem)",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.6,
      "unit": "rem"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "publication",
      "name": "Publication",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Publication name",
          "default": "Vogue"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo (optional)",
          "info": "Upload a logo to replace the text wordmark. Works best as a transparent PNG."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)",
          "info": "Link to the article or publication"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press Logos",
      "blocks": [
        {
          "type": "publication",
          "settings": { "name": "Vogue Germany" }
        },
        {
          "type": "publication",
          "settings": { "name": "arte magazin" }
        },
        {
          "type": "publication",
          "settings": { "name": "Fräulein" }
        },
        {
          "type": "publication",
          "settings": { "name": "Discover Germany" }
        },
        {
          "type": "publication",
          "settings": { "name": "Chicle Magazine" }
        }
      ]
    }
  ]
}
{% endschema %}
