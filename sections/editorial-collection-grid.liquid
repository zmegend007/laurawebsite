{%- style -%}
  .ecg {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  .ecg__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2.4rem, 3.5vw, 4.2rem);
    font-weight: 200;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 4rem;
  }

  .ecg__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .ecg__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.6rem;
    }
  }

  /* Asymmetric: odd rows = large left, even rows = large right */
  @media screen and (min-width: 750px) {
    .ecg__item:nth-child(6n+1) { grid-row: span 2; }
    .ecg__item:nth-child(6n+4) { grid-column: 2; grid-row: span 2; }
  }

  .ecg__item {
    position: relative;
    overflow: hidden;
  }

  .ecg__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ecg__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  /* Large items get taller aspect ratio */
  @media screen and (min-width: 750px) {
    .ecg__item:nth-child(6n+1) .ecg__image-wrap,
    .ecg__item:nth-child(6n+4) .ecg__image-wrap {
      aspect-ratio: 3 / 4;
    }
  }

  .ecg__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ecg__link:hover .ecg__image-wrap img {
    transform: scale(1.04);
  }

  .ecg__info {
    padding: 1.4rem 0 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ecg__link:hover .ecg__info {
    transform: translateY(-4px);
  }

  .ecg__name {
    font-family: var(--font-heading-family);
    font-size: clamp(1.1rem, 1.4vw, 1.4rem);
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
  }

  .ecg__count {
    font-family: var(--font-body-family);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    opacity: 0.35;
    margin-top: 0.3rem;
  }
{%- endstyle -%}

<section class="ecg color-{{ section.settings.color_scheme }}">
  {% if section.settings.heading != blank %}
    <h2 class="ecg__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="ecg__grid">
    {% for block in section.blocks %}
      {%- assign collection = collections[block.settings.collection] -%}
      {% if collection != blank %}
        <div class="ecg__item" {{ block.shopify_attributes }}>
          <a href="{{ collection.url }}" class="ecg__link">
            <div class="ecg__image-wrap">
              {% if collection.image %}
                <img
                  src="{{ collection.image | image_url: width: 900 }}"
                  srcset="{{ collection.image | image_url: width: 450 }} 450w,
                          {{ collection.image | image_url: width: 700 }} 700w,
                          {{ collection.image | image_url: width: 900 }} 900w"
                  sizes="(min-width: 750px) 50vw, 100vw"
                  alt="{{ collection.title | escape }}"
                  loading="lazy"
                  width="{{ collection.image.width }}"
                  height="{{ collection.image.height }}"
                >
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <div class="ecg__info">
              <h3 class="ecg__name">{{ collection.title }}</h3>
              <p class="ecg__count">{{ collection.all_products_count }} {{ collection.all_products_count | pluralize: 'piece', 'pieces' }}</p>
            </div>
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Editorial Collection Grid",
  "tag": "section",
  "class": "section-ecg",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Categories"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Collection Grid",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
