{%- style -%}
  .ea {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    position: relative;
  }

  .ea__rule {
    width: 60px;
    height: 1px;
    background: rgba(var(--color-foreground), 0.12);
    margin: 0 auto 4rem;
  }

  .ea__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    max-width: var(--page-width);
    margin: 0 auto;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .ea__grid {
      grid-template-columns: 55% 45%;
    }
  }

  .ea__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .ea__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ea:hover .ea__image-wrap img {
    transform: scale(1.03);
  }

  .ea__content {
    padding: 3rem 2rem;
  }

  @media screen and (min-width: 750px) {
    .ea__content {
      padding: 4rem 5rem;
    }
  }

  .ea__label {
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.3;
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .ea__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2.4rem, 3.5vw, 4rem);
    font-weight: 200;
    letter-spacing: 0.06em;
    line-height: 1.1;
    margin: 0 0 2rem;
  }

  .ea__text {
    font-size: 1.4rem;
    line-height: 1.85;
    color: rgba(var(--color-foreground), 0.5);
    margin-bottom: 3rem;
  }

  @media screen and (min-width: 750px) {
    .ea__text {
      font-size: 1.5rem;
    }
  }

  .ea__cta {
    display: inline-block;
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.3);
    padding-bottom: 4px;
    transition: border-color 0.4s ease, opacity 0.4s ease;
  }

  .ea__cta:hover {
    border-color: rgb(var(--color-foreground));
    opacity: 0.7;
  }
{%- endstyle -%}

<section class="ea color-{{ section.settings.color_scheme }}">
  <div class="ea__rule"></div>

  <div class="ea__grid">
    <div class="ea__image-wrap">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          srcset="{{ section.settings.image | image_url: width: 450 }} 450w,
                  {{ section.settings.image | image_url: width: 700 }} 700w,
                  {{ section.settings.image | image_url: width: 900 }} 900w"
          sizes="(min-width: 750px) 55vw, 100vw"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    <div class="ea__content">
      {% if section.settings.label != blank %}
        <p class="ea__label">{{ section.settings.label }}</p>
      {% endif %}

      <h2 class="ea__heading">{{ section.settings.heading }}</h2>

      <div class="ea__text">{{ section.settings.text }}</div>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="ea__cta">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial About",
  "tag": "section",
  "class": "section-editorial-about",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Portrait photo"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "About"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About Laura"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Berlin-based fashion stylist with a passion for creating memorable looks. Years of experience in editorial, event, and personal styling — blending high fashion with individual expression.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Editorial About"
    }
  ]
}
{% endschema %}
