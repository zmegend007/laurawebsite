{% doc %}
  @prompt
    editorial grid that fits 15 products with mixed sizes of the cards. make it fancy with glowing frames, only 3:4, 1:1 and rectangle ratios please. add options to adjust for mobile screens., maximum 12 products but make sure they are all visible, i can only see 6 out of 15 populated slots
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-editorial-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-editorial-grid__card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease;
  }

  .ai-editorial-grid__card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(
      {{ block.settings.glow_angle }}deg,
      {{ block.settings.glow_color_1 }},
      {{ block.settings.glow_color_2 }},
      {{ block.settings.glow_color_3 }},
      {{ block.settings.glow_color_1 }}
    );
    border-radius: {{ block.settings.card_border_radius }}px;
    opacity: {{ block.settings.glow_opacity }};
    z-index: -1;
    filter: blur({{ block.settings.glow_blur }}px);
  }

  .ai-editorial-grid__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-editorial-grid__card-{{ ai_gen_id }}:hover::before {
    opacity: {{ block.settings.glow_opacity_hover }};
  }

  .ai-editorial-grid__card-{{ ai_gen_id }}--portrait {
    grid-column: span 1;
  }

  .ai-editorial-grid__card-{{ ai_gen_id }}--square {
    grid-column: span 1;
  }

  .ai-editorial-grid__card-{{ ai_gen_id }}--landscape {
    grid-column: span 2;
  }

  .ai-editorial-grid__card-link-{{ ai_gen_id }} {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ai-editorial-grid__card-content-{{ ai_gen_id }} {
    position: relative;
    height: 100%;
  }

  .ai-editorial-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-editorial-grid__card-{{ ai_gen_id }}--portrait .ai-editorial-grid__image-wrapper-{{ ai_gen_id }} {
    padding-bottom: 133.33%;
  }

  .ai-editorial-grid__card-{{ ai_gen_id }}--square .ai-editorial-grid__image-wrapper-{{ ai_gen_id }} {
    padding-bottom: 100%;
  }

  .ai-editorial-grid__card-{{ ai_gen_id }}--landscape .ai-editorial-grid__image-wrapper-{{ ai_gen_id }} {
    padding-bottom: 66.67%;
  }

  .ai-editorial-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-grid__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-editorial-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-editorial-grid__info-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.card_padding }}px;
    background: linear-gradient(to top, {{ block.settings.card_background }}ee 0%, {{ block.settings.card_background }}cc 60%, transparent 100%);
    z-index: 1;
  }

  .ai-editorial-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
    line-height: 1.3;
  }

  .ai-editorial-grid__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 500;
  }

  .ai-editorial-grid__cta-{{ ai_gen_id }} {
    text-align: center;
    padding: {{ block.settings.grid_gap }}px 0 0;
  }

  .ai-editorial-grid__cta-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 48px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    border: 1px solid {{ block.settings.text_color }};
    background: transparent;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .ai-editorial-grid__cta-link-{{ ai_gen_id }}:hover {
    background: {{ block.settings.text_color }};
    color: {{ block.settings.card_background }};
  }

  .ai-editorial-grid__empty-state-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-editorial-grid__empty-state-{{ ai_gen_id }} p {
    font-size: 16px;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }

    .ai-editorial-grid__card-{{ ai_gen_id }}--portrait {
      grid-column: span 1;
    }

    .ai-editorial-grid__card-{{ ai_gen_id }}--square {
      grid-column: span 1;
    }

    .ai-editorial-grid__card-{{ ai_gen_id }}--landscape {
      grid-column: span 2;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-grid__container-{{ ai_gen_id }} {
      {% if block.settings.mobile_columns == '1' %}
        grid-template-columns: 1fr;
      {% else %}
        grid-template-columns: repeat(2, 1fr);
      {% endif %}
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-editorial-grid__card-{{ ai_gen_id }}--portrait,
    .ai-editorial-grid__card-{{ ai_gen_id }}--square,
    .ai-editorial-grid__card-{{ ai_gen_id }}--landscape {
      grid-column: span 1;
    }

    {% if block.settings.mobile_aspect_ratio == 'portrait' %}
      .ai-editorial-grid__card-{{ ai_gen_id }}--portrait .ai-editorial-grid__image-wrapper-{{ ai_gen_id }},
      .ai-editorial-grid__card-{{ ai_gen_id }}--square .ai-editorial-grid__image-wrapper-{{ ai_gen_id }},
      .ai-editorial-grid__card-{{ ai_gen_id }}--landscape .ai-editorial-grid__image-wrapper-{{ ai_gen_id }} {
        padding-bottom: 133.33%;
      }
    {% elsif block.settings.mobile_aspect_ratio == 'square' %}
      .ai-editorial-grid__card-{{ ai_gen_id }}--portrait .ai-editorial-grid__image-wrapper-{{ ai_gen_id }},
      .ai-editorial-grid__card-{{ ai_gen_id }}--square .ai-editorial-grid__image-wrapper-{{ ai_gen_id }},
      .ai-editorial-grid__card-{{ ai_gen_id }}--landscape .ai-editorial-grid__image-wrapper-{{ ai_gen_id }} {
        padding-bottom: 100%;
      }
    {% elsif block.settings.mobile_aspect_ratio == 'landscape' %}
      .ai-editorial-grid__card-{{ ai_gen_id }}--portrait .ai-editorial-grid__image-wrapper-{{ ai_gen_id }},
      .ai-editorial-grid__card-{{ ai_gen_id }}--square .ai-editorial-grid__image-wrapper-{{ ai_gen_id }},
      .ai-editorial-grid__card-{{ ai_gen_id }}--landscape .ai-editorial-grid__image-wrapper-{{ ai_gen_id }} {
        padding-bottom: 66.67%;
      }
    {% endif %}

    .ai-editorial-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-editorial-grid__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<editorial-grid-{{ ai_gen_id }} class="ai-editorial-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% liquid
    assign card_ratios = 'portrait,square,landscape,portrait,square,landscape,square,portrait,landscape,portrait,square,landscape' | split: ','
    assign has_products = false
    for i in (1..12)
      assign product_key = 'product_' | append: i
      assign product = block.settings[product_key]
      if product != blank
        assign has_products = true
        break
      endif
    endfor
  %}

  {% if has_products %}
    <div class="ai-editorial-grid__container-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% liquid
          assign product_key = 'product_' | append: i
          assign product = block.settings[product_key]
          assign ratio_index = i | minus: 1
          assign card_ratio = card_ratios[ratio_index]
        %}

        {% if product != blank %}
          <div class="ai-editorial-grid__card-{{ ai_gen_id }} ai-editorial-grid__card-{{ ai_gen_id }}--{{ card_ratio }}">
            <a href="{{ product.url }}" class="ai-editorial-grid__card-link-{{ ai_gen_id }}">
              <div class="ai-editorial-grid__card-content-{{ ai_gen_id }}">
                <div class="ai-editorial-grid__image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 800 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-editorial-grid__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="800"
                      height="800"
                    >
                  {% else %}
                    <div class="ai-editorial-grid__image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-editorial-grid__info-{{ ai_gen_id }}">
                  <h3 class="ai-editorial-grid__title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <div class="ai-editorial-grid__price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </div>
                </div>
              </div>
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div class="ai-editorial-grid__empty-state-{{ ai_gen_id }}">
      <p>Next, add products to create your editorial grid</p>
    </div>
  {% endif %}
  <div class="ai-editorial-grid__cta-{{ ai_gen_id }}">
    <a href="/collections/for-rent" class="ai-editorial-grid__cta-link-{{ ai_gen_id }}">SEE ALL</a>
  </div>
</editorial-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const container = this.querySelector('.ai-editorial-grid__container-{{ ai_gen_id }}');
        if (container) {
          container.setAttribute('role', 'list');
        }
      }
    }

    customElements.define('editorial-grid-{{ ai_gen_id }}', EditorialGrid{{ ai_gen_id }});
  })();
</script>

